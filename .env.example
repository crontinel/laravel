# ---------------------------------------------------------------
# Crontinel OSS Package — Test/Dev Environment
# Copy this file to .env when running the test Laravel app locally.
# ---------------------------------------------------------------

# SaaS connection (optional — only needed when testing SaaS reporting)
CRONTINEL_API_KEY=
CRONTINEL_API_URL=https://app.crontinel.com/api

# Alert channels (optional — only needed when testing alerts locally)
CRONTINEL_SLACK_WEBHOOK=
CRONTINEL_ALERT_EMAIL=

# Dashboard path override (optional — default: crontinel)
# CRONTINEL_PATH=crontinel
